{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(uv:*)",
      "Bash(find:*)",
      "Bash(mv:*)",
      "Bash(grep:*)",
      "Bash(npm:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Write",
      "Edit",
      "Bash(chmod:*)",
      "Bash(touch:*)",
      "Bash(rm -f ~/.claude/hooks/.quiet)",
      "Bash(touch ~/.claude/hooks/.quiet)",
      "Edit(~/.claude/hooks/.quiet)",
      "Bash(rm -f ~/.claude/hooks/.quiet-subagent)",
      "Bash(touch ~/.claude/hooks/.quiet-subagent)",
      "Edit(~/.claude/hooks/.quiet-subagent)",
      "Bash(rm -f ~/.claude/hooks/.allow-env)",
      "Bash(touch ~/.claude/hooks/.allow-env)",
      "Edit(~/.claude/hooks/.allow-env)",
      "Write(*/onboard-*.md)",
      "Bash(md-to-pdf:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$PWD\" && uv run ~/.claude/hooks/pre_tool_use.py'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$PWD\" && uv run ~/.claude/hooks/post_tool_use.py'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$PWD\" && uv run ~/.claude/hooks/notification.py --notify'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$PWD\" && uv run ~/.claude/hooks/stop.py --chat'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cd \"$PWD\" && uv run ~/.claude/hooks/subagent_stop.py'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "everything-claude-code@everything-claude-code": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1753999993659
  }
}
